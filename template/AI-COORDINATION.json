{
  "schemaVersion": 1,
  "canonicalBranch": "main",
  "aiBranchPrefixes": [
    "ai/",
    "agent/",
    "codex/",
    "claude/",
    "gemini/",
    "copilot/"
  ],
  "manifestDirectory": ".ai-work/changes",
  "integrationStateFile": "AI-INTEGRATION-STATE.json",
  "integrationMode": "serialized-fresh-base",
  "requireSeparateWorkspace": true,
  "requireDeclaredScope": true,
  "requireFreshCanonicalBase": true,
  "requireDraftPullRequest": true,
  "githubProtection": {
    "automaticSetup": true,
    "setupScript": "scripts/configure-github-protection.ps1",
    "rulesetName": "Проектная основа: единая версия",
    "requiredStatusCheck": "Одна согласованная версия проекта",
    "requirePullRequest": true,
    "requireUpToDateBranch": true,
    "blockForcePushes": true,
    "blockDeletion": true,
    "allowBypass": false
  }
}
